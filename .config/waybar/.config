{
  "layer": "top",
  "position": "top",

  "width": 1728,
  "height": 36,

  "margin-top": 10,
  "margin-left": 0,
  "margin-right": 0,

  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "cpu",
    "memory",
    "custom/music",
    "custom/cava"
  ],

  "modules-center": [
    "clock"
  ],

  "modules-right": [
    "custom/wifi",
    "backlight",
    "pulseaudio",
    "battery",
    "custom/power"
  ],

  // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  // IZQUIERDA
  // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

  "custom/launcher": {
    "format": "пЊѓ",
    "tooltip": false,
    "on-click": "rofi -show drun"
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "on-click": "activate",
    "all-outputs": true,
    "active-only": false,

    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": [],
      "6": []
    },

    "format": "{icon}",
    "format-icons": {
      "active": "<span font='12'>у°®Ї</span>",
      "empty": "<span font='8'>п„‘</span>",
      "persistent": "у°Љ "
    }
  },

  "cpu": {
    "format": "п’ј {usage}%",
    "tooltip": false
  },

  "memory": {
    "format": "ої… {used:0.1f}G",
    "tooltip": false
  },

  "custom/music": {
    "exec": "playerctl metadata --format '{{ artist }} - {{ title }}'",
    "interval": 2,
    "format": "пЂЃ {}",
    "tooltip": false,
    "on-click": "playerctl play-pause"
  },

  "custom/cava": {
    "exec": "~/.config/waybar/scripts/cava.sh",
    "interval": 1,
    "format": "{}",
    "tooltip": false
  },

  // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  // CENTRO
  // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

  "clock": {
    "format": "пЂ— {:%H:%M:%S}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>",
    "on-click": "gsimplecal"
  },

  // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  // DERECHA
  // в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

  "custom/wifi": {
    "format": "п‡«",
    "tooltip": false,
    "on-click": "~/.config/rofi/wifi-menu.sh"
  },

  "backlight": {
    "format": "у°ѓћ {percent}%",
    "tooltip": false,
    "scroll-step": 5
  },

  "pulseaudio": {
    "format": "пЂЁ {volume}%",
    "format-muted": "у°ќџ",
    "tooltip": false,
    "scroll-step": 5
  },

  "battery": {
    "format": "п‰Ђ {capacity}%",
    "format-charging": "пѓ§ {capacity}%",
    "tooltip": false
  },

  "custom/power": {
    "format": "пЂ‘",
    "tooltip": false,
    "on-click": "~/.config/rofi/powermenu.sh"
  }
}

